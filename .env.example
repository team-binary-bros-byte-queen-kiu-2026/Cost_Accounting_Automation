# ── OpenRouter ──────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-your-key-here

# ── MCP Server ───────────────────────────────────────────────────────────────
MCP_BEARER_TOKEN=change-this-secret-token

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_PATH=./backend/database/prices.db

# ── RAG / ChromaDB ───────────────────────────────────────────────────────────
CHROMA_DB_PATH=./chroma_db

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
BACKEND_PORT=8000
MCP_SERVER_PORT=8001
FRONTEND_URL=http://localhost:3000
