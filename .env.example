# ── OpenRouter ──────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-your-key-here

# ── Model fallback chain (Lab 11 — change without editing code) ───────────────
PRIMARY_MODEL=anthropic/claude-3-5-haiku
SECONDARY_MODEL=anthropic/claude-3-5-haiku
OSS_FALLBACK=openai/gpt-4o-mini
PRIMARY_VISION_MODEL=google/gemini-3-flash

# ── MCP Server ───────────────────────────────────────────────────────────────
MCP_BEARER_TOKEN=change-this-secret-token

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_PATH=./backend/database/prices.db

# ── RAG / ChromaDB ───────────────────────────────────────────────────────────
CHROMA_DB_PATH=./chroma_db

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
BACKEND_PORT=8000
MCP_SERVER_PORT=8001
FRONTEND_URL=http://localhost:3000
